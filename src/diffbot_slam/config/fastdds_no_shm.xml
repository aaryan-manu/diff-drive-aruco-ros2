<?xml version="1.0" encoding="UTF-8" ?>
<profiles xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">

    <!--
        FastDDS profile for DiffBot SLAM simulation.

        Uses default transports (SHM + UDPv4) for best performance and
        message ordering on same-host communication.  SHM delivers messages
        sequentially through shared memory, avoiding the UDP packet
        reordering that causes TF "jump back in time" errors.

        Stale SHM segments from crashed sessions are cleaned up automatically
        by the launch file before any node starts.
    -->
    <participant profile_name="default_participant" is_default_profile="true">
        <rtps>
            <!-- Use built-in transports: SHM (primary) + UDPv4 (fallback) -->
            <useBuiltinTransports>true</useBuiltinTransports>
        </rtps>
    </participant>

</profiles>
